generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model PagamentoGuia {
  chave_nfe      String   @id
  data_pagamento DateTime @default(now())
  valor          Float    @default(0.0)
  observacoes    String   @default("")

  @@map("com_pagamento_guia")
}

model NfeConciliacao {
  chave_nfe      String   @id
  emitente       String
  cnpj_emitente  String?
  data_emissao   DateTime
  valor_total    Float
  xml_completo   String   @db.Text
  
  // Status Analysis (User Input)
  status_analise String   @default("Tributado - Verificado")
  valor_guia     Float    @default(0.0)
  
  // ERP Status (ETL)
  status_erp     String   @default("PENDENTE") // PENDENTE, LANCADA, EXCLUIDA

  // Data de entrada confirmada na NF_ENTRADA do ERP (preenchida ao confirmar lançamento)
  dt_entrada     DateTime?

  // Operation Details
  tipo_operacao       Int    @default(0) // 0 - Entrada, 1 - Saída
  tipo_operacao_desc  String @default("ENTRADA PRÓPRIA")
  tipo_imposto        String?

  // Alerta de MVA acima do padrão (NF interestadual) — ver maybeAlertMva()
  mva_verificado_em     DateTime?         // regra de MVA já avaliada para esta NF
  mva_alerta_enviado_em DateTime?         // WhatsApp já disparado (anti-duplicidade)
  mva_maior             Float?            // maior pMVAST encontrado na nota

  // Auditoria fiscal do lançamento (NF LANCADA) — ver auditarLancamentoFiscal()
  auditoria_fiscal_em     DateTime?       // auditoria já executada para esta NF
  auditoria_fiscal_status String?         // OK | DIVERGENTE | SEM_CONFERENCIA
  auditoria_alerta_em     DateTime?       // WhatsApp de auditoria já disparado (anti-duplicidade)

  updated_at     DateTime @updatedAt
  created_at     DateTime @default(now())

  @@map("com_nfe_conciliacao")
}

// CT-e de entrada (modelo 57) espelhado do ERP, igual à NF-e (com_nfe_conciliacao).
// Fonte: CTE_DISTRIBUICAO (pendentes) + NF_ENTRADA modelo 57 (lançadas) + CTE_ENTRADA_XML (XML).
model CteDocumento {
  chave_acesso String @id // 44 dígitos do CT-e

  numero  String?
  serie   String?
  cfop    String?

  emitente_nome     String? // transportadora
  emitente_cnpj     String?
  remetente_nome    String?
  destinatario_nome String?

  origem  String? // "MUN/UF" de início da prestação
  destino String? // "MUN/UF" de fim da prestação

  valor_total  Float?    @default(0)
  data_emissao DateTime?

  // Status do espelho: PENDENTE (CTE_DISTRIBUICAO) | LANCADA (NF_ENTRADA modelo 57)
  status     String    @default("PENDENTE")
  dt_entrada DateTime? // preenchida quando LANCADA

  // Frete sobre COMPRA (destinatário = nossa empresa) | VENDA (remetente = nossa empresa) | OUTRO
  tipo_frete String @default("OUTRO")

  // Responsável pelo pagamento do frete (tomador) e se é a nossa empresa
  tomador_nome       String?
  tomador_cnpj       String?
  modalidade_pagador String? // REMETENTE | DESTINATÁRIO | EXPEDIDOR | RECEBEDOR | OUTROS
  tomador_nos        Boolean @default(false)

  xml_completo String  @db.Text // gzip+base64 (mesmo encode da NF-e) ou XML puro
  dados_json   Json? // CteData já parseado p/ a tela e o DACTE
  hash         String?

  // ---- Rastreio SSW (movimentação física da carga) — ver cte-rastreio.* ----
  // Movimentação derivada do SSW. NULL = ainda não consultado. EM_TRANSITO | ENTREGUE.
  rastreio_status       String?
  // Cobertura: COBERTO (transportadora responde no SSW) | SEM_RASTREIO (fora do SSW).
  rastreio_cobertura    String?
  rastreio_dominio      String? // domínio SSW que respondeu (ex.: GTR, DUM, OTC)
  rastreio_previsao     DateTime? // previsão de entrega informada pelo SSW
  rastreio_entregue_em  DateTime? // data/hora do evento de entrega
  rastreio_recebedor    String? // quem recebeu (preenchido na entrega)
  rastreio_ult_evento   String? // descrição da última ocorrência
  rastreio_ult_consulta DateTime? // última vez que consultamos o SSW
  rastreio_tentativas   Int       @default(0) // consultas sem documento localizado (p/ marcar SEM_RASTREIO)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([data_emissao])
  @@index([status])
  @@index([numero])
  @@index([rastreio_status])
  @@map("com_cte_documento")
}

// Eventos de movimentação (timeline) de um CT-e, captados do SSW (trackingdanfe).
// Dedupe por (chave_acesso, data_hora, codigo_ssw) para não duplicar a cada polling.
model CteRastreioEvento {
  id             Int      @id @default(autoincrement())
  chave_acesso   String // CT-e em com_cte_documento
  data_hora      DateTime // data/hora da ocorrência (SSW)
  codigo_ssw     String? // código numérico da ocorrência (ex.: 80, 1)
  ocorrencia     String? // título da ocorrência
  descricao      String?  @db.Text // detalhe livre da ocorrência
  cidade         String? // "SAO PAULO / SP"
  filial         String? // filial do SSW
  tipo           String? // Informativo | ...
  nome_recebedor String? // preenchido na entrega
  dominio        String? // domínio SSW que respondeu
  created_at     DateTime @default(now())

  @@unique([chave_acesso, data_hora, codigo_ssw], name: "uq_cte_evento")
  @@index([chave_acesso])
  @@map("com_cte_rastreio_evento")
}

// Cobertura SSW por transportadora (CNPJ-raiz, 8 dígitos). Auto-aprendida pelo cron:
// coberta=null (desconhecida) → true (respondeu no SSW) | false (fora do SSW).
model CteTransportadoraCobertura {
  cnpj_raiz              String    @id // 8 primeiros dígitos do CNPJ da transportadora
  nome                   String?
  coberta                Boolean? // null = desconhecida; true = SSW; false = fora do SSW
  dominio                String? // último domínio SSW observado
  tentativas_sem_sucesso Int       @default(0)
  ultima_verificacao     DateTime?
  atualizado_em          DateTime  @updatedAt

  @@map("com_cte_transportadora_cobertura")
}

// Ponteiro de NSU da distribuição de NFS-e (ADN) por CNPJ consultado.
model NfseDistControle {
  cnpj            String   @id
  ultimo_nsu      BigInt   @default(0)
  max_nsu         BigInt   @default(0)
  ultima_consulta DateTime?
  atualizado_em   DateTime @updatedAt

  @@map("com_nfse_dist_controle")
}

// NFS-e Nacional captada da ADN. Chave = entidade da nota (upsert por chave).
// Mudanças (substituição) atualizam a linha; eventos alteram a `situacao`.
model NfseDocumento {
  chave_acesso      String    @id
  cnpj_destinatario String
  ultimo_nsu        BigInt    @default(0)
  numero            String?
  serie             String?
  cnpj_prestador    String?
  nome_prestador    String?
  cnpj_tomador      String?
  nome_tomador      String?
  valor             Float?
  retencao_federal  Float     @default(0) // soma PIS+COFINS+IRRF+CSLL+INSS retidos
  data_emissao      DateTime?
  competencia       DateTime?
  situacao          String    @default("NORMAL") // NORMAL | CANCELADA | SUBSTITUIDA
  papel             String? // PRESTADOR | TOMADOR | INTERMEDIARIO
  xml               String    @db.Text
  hash              String? // detecta mudança no XML p/ decidir atualizar
  dados_json        Json?
  processado        Boolean   @default(false)
  created_at        DateTime  @default(now())
  updated_at        DateTime  @updatedAt

  @@index([cnpj_prestador])
  @@index([data_emissao])
  @@index([numero])
  @@map("com_nfse_documento")
}

// Eventos vinculados a uma NFS-e (cancelamento, substituição, etc.).
model NfseEvento {
  nsu          BigInt    @id
  chave_acesso String
  tipo_evento  String?
  data_evento  DateTime?
  xml          String    @db.Text
  dados_json   Json?
  created_at   DateTime  @default(now())

  @@index([chave_acesso])
  @@map("com_nfse_evento")
}

// Certificado e-CNPJ A1 vinculado pelo frontend (mTLS da ADN).
// A senha é guardada cifrada (AES-256-GCM) quando NFSE_CERT_SECRET existe.
model NfseCertificado {
  cnpj          String   @id
  nome          String?
  arquivo       Bytes // conteúdo do .pfx
  senha         String // cifrada (enc:v1:...) ou texto puro (fallback)
  validade_ate  DateTime?
  ativo         Boolean  @default(true)
  atualizado_em DateTime @updatedAt
  created_at    DateTime @default(now())

  @@map("com_nfse_certificado")
}
