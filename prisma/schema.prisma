generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model PagamentoGuia {
  chave_nfe      String   @id
  data_pagamento DateTime @default(now())
  valor          Float    @default(0.0)
  observacoes    String   @default("")

  @@map("com_pagamento_guia")
}

model NfeConciliacao {
  chave_nfe      String   @id
  emitente       String
  cnpj_emitente  String?
  data_emissao   DateTime
  valor_total    Float
  xml_completo   String   @db.Text
  
  // Status Analysis (User Input)
  status_analise String   @default("Tributado - Verificado")
  valor_guia     Float    @default(0.0)
  
  // ERP Status (ETL)
  status_erp     String   @default("PENDENTE") // PENDENTE, LANCADA, EXCLUIDA

  // Data de entrada confirmada na NF_ENTRADA do ERP (preenchida ao confirmar lançamento)
  dt_entrada     DateTime?

  // Operation Details
  tipo_operacao       Int    @default(0) // 0 - Entrada, 1 - Saída
  tipo_operacao_desc  String @default("ENTRADA PRÓPRIA")
  tipo_imposto        String?

  // Alerta de MVA acima do padrão (NF interestadual) — ver maybeAlertMva()
  mva_verificado_em     DateTime?         // regra de MVA já avaliada para esta NF
  mva_alerta_enviado_em DateTime?         // WhatsApp já disparado (anti-duplicidade)
  mva_maior             Float?            // maior pMVAST encontrado na nota

  // Auditoria fiscal do lançamento (NF LANCADA) — ver auditarLancamentoFiscal()
  auditoria_fiscal_em     DateTime?       // auditoria já executada para esta NF
  auditoria_fiscal_status String?         // OK | DIVERGENTE | SEM_CONFERENCIA
  auditoria_alerta_em     DateTime?       // WhatsApp de auditoria já disparado (anti-duplicidade)

  updated_at     DateTime @updatedAt
  created_at     DateTime @default(now())

  @@map("com_nfe_conciliacao")
}
